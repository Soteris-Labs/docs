{
  "theme": "linden",
  "name": "Soteris Docs",
  "description": "Partner-facing documentation for Soteris integrations, engagement states, artifact delivery, and verification.",
  "colors": {
    "primary": "#0F0503",
    "light": "#E8DCC2",
    "dark": "#0F0503"
  },
  "logo": {
    "light": "https://soterislabs.xyz/brand/soteris-wordmark.svg",
    "dark": "https://soterislabs.xyz/brand/soteris-wordmark-dark.svg",
    "href": "https://soterislabs.xyz"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#E8DCC2",
      "dark": "#0F0503"
    }
  },
  "navbar": {
    "links": [
      {
        "href": "/",
        "label": "Docs"
      },
      {
        "href": "/reference/lifecycle-enum",
        "label": "Reference"
      },
      {
        "href": "https://app.soterislabs.xyz",
        "label": "Portal"
      },
      {
        "href": "https://soterislabs.xyz",
        "label": "Website"
      },
      {
        "href": "https://github.com/Soteris-Labs",
        "label": "GitHub"
      }
    ]
  },
  "icons": {
    "library": "tabler"
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "dark"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "mcp"
    ],
    "display": "header"
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/start/overview",
      "permanent": false
    },
    {
      "source": "/index",
      "destination": "/start/overview",
      "permanent": false
    }
  ],
  "$schema": "https://mintlify.com/docs.json",
  "navigation": {
    "groups": [
      {
        "group": "Start",
        "icon": "chevron-right",
        "pages": [
          "start/overview",
          "start/integration-surfaces",
          "start/access-model",
          "start/agent-guide",
          "start/disclosure-boundary"
        ]
      },
      {
        "group": "Workflow",
        "icon": "workflow",
        "pages": [
          "state-machine/lifecycle-overview",
          "state-machine/public-states",
          "state-machine/state-transitions",
          "state-machine/exception-paths",
          "state-machine/actor-boundaries",
          "state-machine/release-conditions"
        ]
      },
      {
        "group": "Artifacts",
        "icon": "package",
        "pages": [
          "packets/input-package",
          "packets/artifact-package",
          "packets/status-card",
          "packets/release-packet",
          "packets/verification-receipt"
        ]
      },
      {
        "group": "Verification",
        "icon": "shield-check",
        "pages": [
          "verification/verification-model",
          "verification/receipt-fields",
          "verification/public-vs-permissioned-checks",
          "verification/what-verification-excludes"
        ]
      },
      {
        "group": "Examples",
        "icon": "flask-conical",
        "pages": [
          "examples/minimal-input-package",
          "examples/minimal-artifact-package",
          "examples/status-handoff",
          "examples/release-receipt",
          "examples/agent-read-path"
        ]
      },
      {
        "group": "Reference",
        "icon": "braces",
        "pages": [
          "reference/lifecycle-enum",
          "reference/packet-schemas",
          "reference/field-dictionary",
          "reference/error-model",
          "reference/exposure-checklist"
        ]
      }
    ]
  }
}
