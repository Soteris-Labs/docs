{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Soteris Developer Docs",
  "description": "Developer documentation for Soteris engagement states, records, and verification.",
  "colors": {
    "primary": "#100907",
    "light": "#FFF4E1",
    "dark": "#100907"
  },
  "logo": {
    "light": "/images/logo-dark.svg",
    "dark": "/images/logo-light.svg",
    "href": "https://soterislabs.xyz"
  },
  "favicon": {
    "light": "/images/icon-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "seo": {
    "metatags": {
      "og:image": "https://docs.soterislabs.xyz/images/og-card.png"
    }
  },
  "background": {
    "color": {
      "light": "#E9DDC4",
      "dark": "#100907"
    }
  },
  "icons": {
    "library": "tabler"
  },
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "banner": {
    "content": "< Soteris v0 contract preview",
    "dismissible": true
  },
  "styling": {
    "eyebrows": "section"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ],
    "display": "header"
  },
  "redirects": [
    { "source": "/", "destination": "/start/overview", "permanent": false },
    { "source": "/index", "destination": "/start/overview", "permanent": false }
  ],
  "navigation": {
    "groups": [
      {
        "group": "Start",
        "icon": "square-arrow-right",
        "pages": [
          "start/overview",
          "start/integration-surfaces",
          "start/access-model",
          "start/agent-guide",
          "start/disclosure-boundary"
        ]
      },
      {
        "group": "Workflow",
        "icon": "robot",
        "pages": [
          "workflow/lifecycle-overview",
          "workflow/public-states",
          "workflow/state-transitions",
          "workflow/exception-paths",
          "workflow/actor-boundaries",
          "workflow/release-conditions"
        ]
      },
      {
        "group": "Records",
        "icon": "database",
        "pages": [
          "records/input-record",
          "records/artifact-record",
          "records/release-record",
          "records/verification-receipt",
          "records/status-card"
        ]
      },
      {
        "group": "Verification",
        "icon": "file-check",
        "pages": [
          "verification/verification-model",
          "verification/receipt-fields",
          "verification/public-vs-permissioned-checks",
          "verification/what-verification-excludes"
        ]
      },
      {
        "group": "Examples",
        "icon": "world-code",
        "pages": [
          "examples/minimal-input-record",
          "examples/minimal-artifact-record",
          "examples/status-handoff",
          "examples/release-receipt",
          "examples/agent-read-path"
        ]
      },
      {
        "group": "Reference",
        "icon": "braces",
        "pages": [
          "reference/lifecycle-enum",
          "reference/record-schemas",
          "reference/field-dictionary",
          "reference/error-model",
          "reference/exposure-checklist"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "href": "/start/agent-guide",
        "label": "Agent Guide"
      },
      {
        "href": "/start/integration-surfaces",
        "label": "Integrations"
      },
      {
        "href": "mailto:hello@soterislabs.xyz",
        "label": "Contact"
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/soterislabs",
      "linkedin": "https://www.linkedin.com/company/soteris-labs"
    }
  },
  "thumbnails": {
    "appearance": "dark"
  }
}
